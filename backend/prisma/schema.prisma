generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * =========================
 * ENUMS
 * =========================
 */

enum OfficerRole {
  PRESIDENT
  VICE_PRESIDENT
  SECOND_VICE_PRESIDENT
  SECRETARY
  TREASURER
  POINTS_SECRETARY

  NATIONAL_DIRECTOR
  STATE_DIRECTOR
  REGION_DIRECTOR
  BOARD_MEMBER

  STUDENT_PRESIDENT
  STUDENT_VICE_PRESIDENT
  STUDENT_SECRETARY
  QUEEN
  JH_PRINCESS
}

enum OfficerType {
  EXECUTIVE
  DIRECTOR
  STUDENT
  STAFF
}

enum AthleteEvent {
  BAREBACK
  SADDLE_BRONC
  BULL_RIDING
  BARREL_RACING
  POLE_BENDING
  GOAT_TYING
  BREAKAWAY_ROPING
  TIE_DOWN_ROPING
  TEAM_ROPING
  STEER_WRESTLING
  RANCH_SADDLE_BRONC
  REINED_COW
}

enum SponsorTier {
  TITLE
  GOLD
  SILVER
  BRONZE
  ATHLETE
}

/**
 * =========================
 * CORE SEASON
 * =========================
 */

model Season {
  id        Int      @id @default(autoincrement())
  year      String   @unique
  startDate DateTime
  endDate   DateTime
  active    Boolean  @default(false)

  events        Event[]
  officers      Officer[]
  announcements Announcement[]
  gallery       GalleryAlbum[]
  athletes      Athlete[]

  createdAt DateTime @default(now())
}

/**
 * =========================
 * LOCATIONS
 * =========================
 */

model Location {
  id            Int      @id @default(autoincrement())
  name          String
  streetAddress String?
  city          String?
  state         String?
  zip           String?
  venueInfo     Json?

  events    Event[]
  createdAt DateTime @default(now())
}

/**
 * =========================
 * CALL-IN POLICY
 * =========================
 */

model CallInPolicy {
  id          Int       @id @default(autoincrement())
  platform    String
  entryOpen   DateTime
  entryClose  DateTime
  lateOpen    DateTime?
  lateClose   DateTime?
  lateContact String?
  notes       String?

  events Event[]
  createdAt DateTime @default(now())
}

/**
 * =========================
 * EVENTS
 * =========================
 */

model Event {
  id   Int    @id @default(autoincrement())
  name String
  slug String @unique

  startDate DateTime
  endDate   DateTime

  seasonId       Int
  locationId     Int
  callInPolicyId Int?

  generalInfo String?
  specials    Json?

  isStateFinals Boolean @default(false)
  status        String  @default("published")

  season       Season        @relation(fields: [seasonId], references: [id])
  location     Location      @relation(fields: [locationId], references: [id])
  callInPolicy CallInPolicy? @relation(fields: [callInPolicyId], references: [id])

  scheduleItems EventScheduleItem[]
  contacts      EventContact[]
  announcements Announcement[]

  createdAt DateTime @default(now())
}

/**
 * =========================
 * EVENT SCHEDULE
 * =========================
 */

model EventScheduleItem {
  id      Int @id @default(autoincrement())
  eventId Int

  label     String
  date      DateTime
  startTime String?
  notes     String?

  event Event @relation(fields: [eventId], references: [id])
  createdAt DateTime @default(now())
}

/**
 * =========================
 * OFFICERS
 * =========================
 */

model Officer {
  id        Int          @id @default(autoincrement())
  name      String
  role      OfficerRole
  type      OfficerType

  email     String?
  phone     String?

  seasonId  Int
  active    Boolean      @default(true)
  createdAt DateTime     @default(now())

  season Season @relation(fields: [seasonId], references: [id])
}

/**
 * =========================
 * EVENT CONTACTS
 * =========================
 */

model EventContact {
  id      Int @id @default(autoincrement())
  eventId Int

  contactRole String
  officerRole String

  event Event @relation(fields: [eventId], references: [id])
  createdAt DateTime @default(now())
}

/**
 * =========================
 * SPONSORS (PHASE 1 LOCKED)
 * =========================
 */

model Sponsor {
  id            Int          @id @default(autoincrement())
  name          String
  tier          SponsorTier

  logoUrl       String
  bannerUrl     String?

  website       String?
  description   String?

  contactName   String?
  contactEmail  String?
  contactPhone  String?

  startDate     DateTime
  endDate       DateTime

  active        Boolean      @default(true)
  internalNotes String?

  athletes      AthleteSponsor[]

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model AthleteSponsor {
  id        Int      @id @default(autoincrement())

  athlete   Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  athleteId Int

  sponsor   Sponsor  @relation(fields: [sponsorId], references: [id], onDelete: Cascade)
  sponsorId Int

  createdAt DateTime @default(now())

  @@unique([athleteId, sponsorId])
}

/**
 * =========================
 * ANNOUNCEMENTS
 * =========================
 */

model Announcement {
  id Int @id @default(autoincrement())

  eventId  Int?
  seasonId Int?

  title   String
  content String?

  mode     String @default("STANDARD")
  imageUrl String?

  sortOrder Int @default(0)
  extras    Json?

  published Boolean  @default(false)
  publishAt DateTime?
  expireAt  DateTime?

  event  Event?  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  season Season? @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/**
 * =========================
 * GALLERY
 * =========================
 */

model GalleryAlbum {
  id       Int    @id @default(autoincrement())
  title    String
  seasonId Int

  coverImage String?
  published  Boolean @default(true)

  season Season @relation(fields: [seasonId], references: [id])
  images GalleryImage[]

  createdAt DateTime @default(now())
}

model GalleryImage {
  id        Int @id @default(autoincrement())
  albumId   Int

  imageUrl  String
  caption   String?
  sortOrder Int @default(0)

  album GalleryAlbum @relation(fields: [albumId], references: [id])
  createdAt DateTime @default(now())
}

/**
 * =========================
 * CUSTOM PAGES
 * =========================
 */

model CustomPage {
  id            Int      @id @default(autoincrement())
  title         String
  slug          String   @unique
  content       String
  status        String

  showInMenu    Boolean  @default(false)
  showInFooter  Boolean  @default(false)
  sortOrder     Int      @default(0)
  isPlaceholder Boolean  @default(false)

  layoutType String  @default("standard")
  sections   Json?
  heroImage  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/**
 * =========================
 * ATHLETES
 * =========================
 */

model Athlete {
  id Int @id @default(autoincrement())

  firstName String
  lastName  String
  school    String?
  grade     String?
  hometown  String?
  bio       String?

  slug String @unique

  headshotUrl    String?
  actionPhotoUrl String?

  seasonId Int
  season   Season? @relation(fields: [seasonId], references: [id])

  events     AthleteEvent[]
  standings  String?
  awards     Json?

  futureGoals String?
  socialLinks Json?

  sponsorLinks AthleteSponsor[]

  isActive   Boolean @default(true)
  isFeatured Boolean @default(false)
  sortOrder  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
