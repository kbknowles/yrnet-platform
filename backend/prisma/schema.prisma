generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OfficerRole {
  // Adult – Executive
  PRESIDENT
  VICE_PRESIDENT
  SECOND_VICE_PRESIDENT
  SECRETARY
  TREASURER
  POINTS_SECRETARY

  // Adult – Directors
  NATIONAL_DIRECTOR
  STATE_DIRECTOR
  REGION_DIRECTOR
  BOARD_MEMBER

  // Student Leadership
  STUDENT_PRESIDENT
  STUDENT_VICE_PRESIDENT
  STUDENT_SECRETARY
  QUEEN
  JH_PRINCESS
}

enum OfficerType {
  EXECUTIVE
  DIRECTOR
  STUDENT
  STAFF
}

enum AthleteEvent {
  BAREBACK
  SADDLE_BRONC
  BULL_RIDING
  BARREL_RACING
  POLE_BENDING
  GOAT_TYING
  BREAKAWAY_ROPING
  TIE_DOWN_ROPING
  TEAM_ROPING
  STEER_WRESTLING
  RANCH_SADDLE_BRONC
  REINED_COW
}


/**
 * =========================
 * CORE SEASON
 * =========================
 */

model Season {
  id        Int      @id @default(autoincrement())
  year      String   @unique
  startDate DateTime
  endDate   DateTime
  active    Boolean  @default(false)

  events        Event[]
  officers      Officer[] 
  announcements Announcement[]
  gallery       GalleryAlbum[]
  athletes       Athlete[]

  createdAt DateTime @default(now())
}

/**
 * =========================
 * LOCATIONS
 * =========================
 */

model Location {
  id            Int      @id @default(autoincrement())
  name          String

  streetAddress String?
  city          String?
  state         String?
  zip           String?

  venueInfo     Json?     // stalls, hookups, parking, notes

  events        Event[]   // deletion blocked if related events exist

  createdAt     DateTime  @default(now())
}


/**
 * =========================
 * CALL-IN POLICY
 * =========================
 */

model CallInPolicy {
  id          Int       @id @default(autoincrement())
  platform    String
  entryOpen   DateTime
  entryClose  DateTime
  lateOpen    DateTime?
  lateClose   DateTime?
  lateContact String?
  notes       String?

  events Event[]

  createdAt DateTime @default(now())
}

/**
 * =========================
 * EVENTS
 * =========================
 */

model Event {
  id   Int    @id @default(autoincrement())
  name String
  slug String @unique

  startDate DateTime
  endDate   DateTime

  seasonId       Int
  locationId     Int
  callInPolicyId Int?

  generalInfo String?
  specials    Json?

  isStateFinals Boolean @default(false)
  status        String  @default("published")

  season       Season        @relation(fields: [seasonId], references: [id])
  location     Location      @relation(fields: [locationId], references: [id])
  callInPolicy CallInPolicy? @relation(fields: [callInPolicyId], references: [id])

  scheduleItems EventScheduleItem[]
  contacts      EventContact[]
  announcements Announcement[]

  createdAt DateTime @default(now())
}

/**
 * =========================
 * EVENT SCHEDULE (TIMELINE)
 * =========================
 */

model EventScheduleItem {
  id      Int @id @default(autoincrement())
  eventId Int

  label     String
  date      DateTime
  startTime String?
  notes     String?

  event Event @relation(fields: [eventId], references: [id])

  createdAt DateTime @default(now())
}

/**
 * =========================
 * OFFICERS
 * =========================
 */

model Officer {
  id        Int          @id @default(autoincrement())
  name      String
  role      OfficerRole
  type      OfficerType

  email     String?      // internal-only (never public)
  phone     String?      // stored raw, masked on render

  seasonId  Int
  active    Boolean      @default(true)
  createdAt DateTime     @default(now())

  season Season @relation(fields: [seasonId], references: [id])
}


/**
 * =========================
 * EVENT CONTACT ROLES
 * =========================
 */

model EventContact {
  id      Int @id @default(autoincrement())
  eventId Int

  contactRole String // entries, membership, obligations
  officerRole String // maps to Officer.role

  event Event @relation(fields: [eventId], references: [id])

  createdAt DateTime @default(now())
}

/**
 * =========================
 * SPONSORS (PHASE 0 VIEW ONLY)
 * =========================
 */

model Sponsor {
  id      Int     @id @default(autoincrement())
  name    String
  logoUrl String?
  website String?
  active  Boolean @default(true)

  createdAt DateTime @default(now())
}


model Announcement {
  id Int @id @default(autoincrement())

  eventId  Int?
  seasonId Int?

  title   String
  content String
  type    String?   // general, entry, stall, reminder
  sortOrder Int @default(0)

  extras Json?

  published Boolean @default(false)
  publishAt DateTime?
  expireAt  DateTime?

  event  Event?  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  season Season? @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/**
 * =========================
 * GALLERY
 * =========================
 */

model GalleryAlbum {
  id       Int    @id @default(autoincrement())
  title    String
  seasonId Int

  coverImage String?
  published  Boolean @default(true)

  season Season @relation(fields: [seasonId], references: [id])
  images GalleryImage[]

  createdAt DateTime @default(now())
}

model GalleryImage {
  id       Int    @id @default(autoincrement())
  albumId Int

  imageUrl String
  caption  String?
  sortOrder Int @default(0)

  album GalleryAlbum @relation(fields: [albumId], references: [id])

  createdAt DateTime @default(now())
}

model CustomPage {
  id           Int      @id @default(autoincrement())
  title        String
  slug         String   @unique
  content      String   // markdown or rich text
  status       String   // "draft" | "published"

  showInMenu   Boolean  @default(false)
  showInFooter Boolean  @default(false)
  sortOrder    Int      @default(0)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}


model Athlete {
  id Int @id @default(autoincrement())

  // Core
  firstName String
  lastName  String
  school    String?
  grade     String?
  hometown  String?
  bio       String?

  slug      String @unique
  
  // Media
  headshotUrl     String?
  actionPhotoUrl String?

  // Rodeo
  seasonId Int
  season   Season? @relation(fields: [seasonId], references: [id])
  
  events AthleteEvent[]   // multi-select dropdown
  standings String?
  awards    Json?         // [{ title, year, event }]

  // Extras
  futureGoals String?
  sponsors    Json?       // [{ name, logoUrl, link }]
  socialLinks Json?       // { instagram, facebook }

  // Admin
  isActive   Boolean @default(true)
  isFeatured Boolean @default(false)
  sortOrder  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
