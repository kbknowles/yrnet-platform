generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/* ================= ENUMS ================= */

enum OfficerRole {
  PRESIDENT
  VICE_PRESIDENT
  SECOND_VICE_PESIDENT
  SECRETARY
  TREASURER
  POINTS_SECRETARY
  NATIONAL_DIRECTOR
  STATE_DIRECTOR
  REGION_DIRECTOR
  BOARD_MEMBER
  STUDENT_PRESIDENT
  STUDENT_VICE_PRESIDENT
  STUDENT_SECRETARY
  QUEEN
  JH_PRINCESS
}

enum OfficerType {
  EXECUTIVE
  DIRECTOR
  STUDENT
  STAFF
}

enum AthleteEvent {
  BAREBACK
  SADDLE_BRONC
  BULL_RIDING
  BARREL_RACING
  POLE_BENDING
  GOAT_TYING
  BREAKAWAY_ROPING
  TIE_DOWN_ROPING
  TEAM_ROPING
  STEER_WRESTLING
  RANCH_SADDLE_BRONC
  REINED_COW
}

enum SponsorshipLevel {
  PREMIER
  FEATURED
  STANDARD
  SUPPORTER
}

enum PlacementZone {
  HEADER
  STRIP
  SIDEBAR
  FOOTER
  INLINE
}

enum ContentType {
  ATHLETE
  EVENT
  LOCATION
  GALLERY
  ANNOUNCEMENT
  SEASON
}

/* ================= TENANT ================= */

model Tenant {
  id           Int      @id @default(autoincrement())
  name         String
  slug         String
  domain       String?
  primaryColor String?
  accentColor  String?
  logoUrl      String?
  active       Boolean  @default(true)

  seasons       Season[]
  locations     Location[]
  callInPolicies CallInPolicy[]
  events        Event[]
  officers      Officer[]
  sponsors      Sponsor[]
  announcements Announcement[]
  galleryAlbums GalleryAlbum[]
  customPages   CustomPage[]
  athletes      Athlete[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/* ================= SEASON ================= */

model Season {
  id        Int      @id @default(autoincrement())
  year      String
  startDate DateTime
  endDate   DateTime
  active    Boolean  @default(false)

  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  events        Event[]
  officers      Officer[]
  announcements Announcement[]
  gallery       GalleryAlbum[]
  athletes      Athlete[]

  createdAt DateTime @default(now())

  @@unique([year, tenantId])
}

/* ================= LOCATION ================= */

model Location {
  id            Int @id @default(autoincrement())
  name          String
  streetAddress String?
  city          String?
  state         String?
  zip           String?
  venueInfo     Json?

  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  events    Event[]
  createdAt DateTime @default(now())
}

/* ================= CALL IN POLICY ================= */

model CallInPolicy {
  id          Int @id @default(autoincrement())
  platform    String
  entryOpen   DateTime
  entryClose  DateTime
  lateOpen    DateTime?
  lateClose   DateTime?
  lateContact String?
  notes       String?

  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  events Event[]
  createdAt DateTime @default(now())
}

/* ================= EVENT ================= */

model Event {
  id   Int    @id @default(autoincrement())
  name String
  slug String

  startDate DateTime
  endDate   DateTime

  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  seasonId       Int
  locationId     Int
  callInPolicyId Int?

  generalInfo String?
  specials    Json?

  isStateFinals Boolean @default(false)
  status        String  @default("published")

  season       Season        @relation(fields: [seasonId], references: [id])
  location     Location      @relation(fields: [locationId], references: [id])
  callInPolicy CallInPolicy? @relation(fields: [callInPolicyId], references: [id])

  scheduleItems EventScheduleItem[]
  contacts      EventContact[]
  announcements Announcement[]

  createdAt DateTime @default(now())

  @@unique([slug, tenantId])
}

/* ================= EVENT SCHEDULE ================= */

model EventScheduleItem {
  id      Int @id @default(autoincrement())
  eventId Int

  label     String
  date      DateTime
  startTime String?
  notes     String?

  event Event @relation(fields: [eventId], references: [id])
  createdAt DateTime @default(now())
}

/* ================= EVENT CONTACT ================= */

model EventContact {
  id      Int @id @default(autoincrement())
  eventId Int

  contactRole String
  officerRole String

  event Event @relation(fields: [eventId], references: [id])
  createdAt DateTime @default(now())
}

/* ================= OFFICER ================= */

model Officer {
  id   Int @id @default(autoincrement())
  name String
  role OfficerRole
  type OfficerType

  email String?
  phone String?

  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  seasonId Int
  active   Boolean @default(true)

  season Season @relation(fields: [seasonId], references: [id])

  createdAt DateTime @default(now())
}

/* ================= SPONSOR ================= */

model Sponsor {
  id          Int @id @default(autoincrement())
  name        String
  logoUrl     String?
  bannerUrl   String?
  website     String?
  description String?

  contactName  String?
  contactEmail String?
  contactPhone String?

  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  active        Boolean @default(true)
  internalNotes String?

  sponsorships Sponsorship[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/* ================= SPONSORSHIP ================= */

model Sponsorship {
  id        Int @id @default(autoincrement())
  sponsorId Int

  sponsor Sponsor @relation(fields: [sponsorId], references: [id], onDelete: Cascade)

  level     SponsorshipLevel
  startDate DateTime
  endDate   DateTime

  contentType ContentType?
  contentId   Int?

  priority Int     @default(0)
  active   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contentType, contentId])
}

/* ================= ANNOUNCEMENT ================= */

model Announcement {
  id Int @id @default(autoincrement())

  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  eventId  Int?
  seasonId Int?

  title   String
  content String?

  mode     String @default("STANDARD")
  imageUrl String?

  sortOrder Int @default(0)
  extras    Json?

  published Boolean  @default(false)
  publishAt DateTime?
  expireAt  DateTime?

  event  Event?  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  season Season? @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/* ================= GALLERY ================= */

model GalleryAlbum {
  id       Int @id @default(autoincrement())
  title    String
  seasonId Int

  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  coverImage String?
  published  Boolean @default(true)

  season Season @relation(fields: [seasonId], references: [id])
  images GalleryImage[]

  createdAt DateTime @default(now())
}

model GalleryImage {
  id        Int @id @default(autoincrement())
  albumId   Int

  imageUrl  String
  caption   String?
  sortOrder Int @default(0)

  album GalleryAlbum @relation(fields: [albumId], references: [id])
  createdAt DateTime @default(now())
}

/* ================= CUSTOM PAGE ================= */

model CustomPage {
  id      Int @id @default(autoincrement())
  title   String
  slug    String
  content String
  status  String

  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  showInMenu    Boolean @default(false)
  showInFooter  Boolean @default(false)
  sortOrder     Int     @default(0)
  isPlaceholder Boolean @default(false)

  layoutType String @default("standard")
  sections   Json?
  heroImage  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([slug, tenantId])
}

/* ================= ATHLETE ================= */

model Athlete {
  id Int @id @default(autoincrement())

  firstName String
  lastName  String
  school    String?
  grade     String?
  hometown  String?
  bio       String?

  slug String

  headshotUrl    String?
  actionPhotoUrl String?

  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  seasonId Int
  season   Season @relation(fields: [seasonId], references: [id])

  events       AthleteEvent[]
  standings    String?
  awards       Json?
  futureGoals  String?
  socialLinks  Json?

  isActive   Boolean @default(true)
  isFeatured Boolean @default(false)
  sortOrder  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([slug, tenantId])
}
